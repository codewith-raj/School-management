NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Preferred for Railway/managed MySQL
DATABASE_URL=

# Local MySQL fallback
DB_HOST=localhost
DB_PORT=3306
DB_NAME=school_management_db
DB_USER=root
DB_PASSWORD=your_mysql_password

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOG_LEVEL=info
ALLOWED_ORIGINS=*

# Deployment stability (optional)
DB_RETRY_DELAY_MS=5000
DB_MAX_RETRIES=12
